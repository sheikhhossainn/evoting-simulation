PORT=3000
SUPABASE_URL=your-supabase-url-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ElGamal keys (run: npx ts-node src/scripts/setup-keys.ts)
NID_HASH_SALT=
ELGAMAL_P=
ELGAMAL_G=
ELGAMAL_PUBLIC_KEY=
ELGAMAL_PRIVATE_KEY=

# Shamir's Secret Sharing (run: npx ts-node src/scripts/setup-shamir.ts)
# SHAMIR_SHARE_1..4 are appended automatically for local testing.

# Salt used to hash keyholder passphrases (see src/config/keyholders.ts).
# Demo keyholders (KH-001/share001 .. KH-004/share004) work without any
# further config. For a real deployment, generate real secrets and set
# KEYHOLDER_PASSPHRASE_HASH_1..4 = sha256(passphrase + this salt) instead.
KEYHOLDER_PASSPHRASE_SALT=

# Shared secret required (via `x-admin-secret` header) for sensitive admin
# routes (POST /anchor/batch, POST /keyshares/tally) until real session-based
# admin auth is implemented.
ADMIN_SECRET=

# Polygon Amoy anchoring (see blockchain/ package — deploy MerkleRootStorage
# there first, then fill these in). Leave blank to disable anchoring;
# /anchor/batch will respond 503 until configured.
AMOY_RPC_URL=
MERKLE_CONTRACT_ADDRESS=
ANCHOR_PRIVATE_KEY=
